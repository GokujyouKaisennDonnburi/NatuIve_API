# このファイルはローカル開発用のテンプレート。コピーして .env を作る（cp .env.example .env）。
# 本番では .env を使わず、実行環境の環境変数やシークレットマネージャで値を注入する。

# サーバの待ち受けポート（未設定なら 8085）
PORT=8085

# 信頼するプロキシ（カンマ区切りの CIDR/IP）。未設定なら全プロキシを信頼しない。
# 開発: 未設定でOK（直接接続）
# 本番: 使用するプロキシの CIDR を設定（例 Cloudflare: 173.245.48.0/20,103.21.244.0/22,...）
# TRUSTED_PROXIES=

# --- データベース ---
# Postgres 接続文字列。未設定なら DB に接続せず起動する。
# docker compose 起動時は compose 側で自動設定されるため未設定でOK。
# ローカルで直接 Postgres に繋ぐ場合に設定する:
# DATABASE_URL=postgres://app:app@localhost:5432/natuive?sslmode=disable

# 起動時にマイグレーションを自動適用するか（開発用）。
# 本番では false にし、デプロイ手順で `make migrate-up GOOSE_EXEC='sh -c'` を実行する（compose 外なのでホスト実行）。
# DB_AUTO_MIGRATE=false

# --- 認証（Supabase Auth の JWT を JWKS で検証する） ---
# Supabase の JWKS エンドポイント。
# 設定すると user 関連 API（/api/v1/me など）が有効になる。未設定なら登録しない。
# 例: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWKS_URL=

# 検証時に要求する JWT の aud クレーム。未設定なら "authenticated"（Supabase 既定）。
# SUPABASE_JWT_AUD=authenticated

# --- ストレージ（Cloudflare R2）---
# R2 の S3 互換 API 認証情報。設定すると presign エンドポイントと画像/PDF 昇格が有効になる。
# 未設定なら storage 系ルートは登録しない（JWKS gating と同じ方針）。
# Cloudflare ダッシュボード > R2 > API トークン から取得する。
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# バケット名（未設定なら "natuportal"）
# R2_BUCKET=natuportal
